{
  "name": "agent",
  "version": "2.0.0",
  "description": "Cross-platform remote desktop host agent for Control.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "build-installer": "node build-installer.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.control.agent",
    "productName": "Control Agent",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "logo.png"
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Control Agent",
      "deleteAppDataOnUninstall": true,
      "artifactName": "ControlAgentInstaller.exe"
    },
    "files": [
      "main.js",
      "index.html",
      "logo.png",
      "package.json",
      ".env",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "asar": false
  },
  "author": "Control Team",
  "license": "ISC",
  "homepage": "https://github.com/boorayash/Control",
  "bugs": {
    "url": "https://github.com/boorayash/Control/issues"
  },
  "type": "commonjs",
  "devDependencies": {
    "buffer": "^6.0.3",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.2",
    "events": "^3.3.0",
    "process": "^0.11.10"
  },
  "dependencies": {
    "@mintplex-labs/nut-js": "^4.2.2",
    "dotenv": "^17.3.1",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.3"
  }
}
