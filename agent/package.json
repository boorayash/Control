{
  "name": "agent",
  "version": "1.0.0",
  "description": "Cross-platform remote desktop host agent for Control.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.control.agent",
    "productName": "ControlAgent",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "artifactName": "ControlAgentInstaller.exe"
    },
    "directories": {
      "output": "dist"
    },
    "asar": false
  },
  "author": "Control Team",
  "license": "ISC",
  "homepage": "https://github.com/boorayash/Control",
  "bugs": {
    "url": "https://github.com/boorayash/Control/issues"
  },
  "type": "commonjs",
  "devDependencies": {
    "buffer": "^6.0.3",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.2",
    "events": "^3.3.0",
    "process": "^0.11.10"
  },
  "dependencies": {
    "@mintplex-labs/nut-js": "^4.2.2",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.3"
  }
}
